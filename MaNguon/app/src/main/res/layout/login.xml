<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/yellow"
    tools:context=".ui.auth.LoginActivity"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="-55dp"
        android:src="@drawable/bee_logo_cut" />

    <TextView
        style="@style/LabelStyle"
        android:text="@string/email_sdt"
        android:layout_marginStart="8dp"/>

    <EditText
        android:id="@+id/edtEmail"
        style="@style/InputStyle"
        android:hint="@string/gmail"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="15dp"/>

    <TextView
        style="@style/LabelStyle"
        android:text="@string/mat_khau"
        android:layout_marginStart="8dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/edtPassWord"
            style="@style/InputStyle"
            android:layout_width="match_parent"
            android:paddingEnd="45dp"
            android:hint="@string/password"
            android:inputType="textPassword"/>

        <ImageView
            android:id="@+id/btnSeePassword"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="15dp"
            android:src="@drawable/eye_close" />
    </RelativeLayout>

    <TextView
        android:id="@+id/txtForgetPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/quen_mk"
        android:padding="15dp"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_gravity="end"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:text="@string/login"
        android:textSize="20sp"
        android:textColor="@color/black"
        app:backgroundTint="@null"
        android:background="@drawable/btn_khung_white"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hoặc"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="40dp"
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="@string/sign_up"
        android:textSize="20sp"
        android:textColor="@color/black"
        app:backgroundTint="@null"
        android:background="@drawable/btn_khung_white"/>
</LinearLayout>