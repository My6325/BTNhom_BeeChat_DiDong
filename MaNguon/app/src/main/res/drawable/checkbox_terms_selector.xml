<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Khung giống btn_khung_white: nền trắng, bo góc register_field_corner_radius -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/white"/>
                    <corners android:radius="8dp"/>
                    <size
                        android:width="32dp"
                        android:height="32dp"/>
                </shape>
            </item>
            <item
                android:bottom="7dp"
                android:left="7dp"
                android:right="7dp"
                android:top="7dp"
                android:drawable="@drawable/checkbox_terms_mark"/>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white"/>
            <corners android:radius="8dp"/>
            <size
                android:width="32dp"
                android:height="32dp"/>
        </shape>
    </item>
</selector>
