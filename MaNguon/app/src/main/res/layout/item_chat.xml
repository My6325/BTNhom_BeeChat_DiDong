<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/layout_avatar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <include
            android:id="@+id/layout_avatar_user"
            layout="@layout/layout_avatar_user" />

        <include
            android:id="@+id/layout_avatar_group"
            layout="@layout/layout_avatar_group"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/txt_user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:textSize="14sp"
        android:hint="Tên user"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="@+id/layout_avatar"
        app:layout_constraintStart_toEndOf="@+id/layout_avatar"
        app:layout_constraintEnd_toStartOf="@+id/img_status_read"/>

    <TextView
        android:id="@+id/txt_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:hint="Tin nhắn mới"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@+id/txt_user_name"
        app:layout_constraintStart_toStartOf="@+id/txt_user_name" />

    <TextView
        android:id="@+id/txt_time"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textSize="14sp"
        android:hint="12:30"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="@+id/txt_message"
        app:layout_constraintStart_toEndOf="@+id/txt_message"
        app:layout_constraintEnd_toStartOf="@+id/img_status_read"/>

    <ImageView
        android:id="@+id/img_status_read"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/circle_on"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>